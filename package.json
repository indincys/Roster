{
  "name": "short-video-ops-workbench",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @roster/desktop run dev",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit packages",
    "test:integration": "vitest run tests/integration",
    "test:e2e:electron": "node tests/e2e/electron-desktop-audit.mjs",
    "test:performance:electron": "node tests/e2e/electron-m7-performance.mjs",
    "release:manifest": "node scripts/generate_update_manifest.mjs",
    "release:verify": "node scripts/verify_release_artifacts.mjs",
    "release:verify:strict": "node scripts/verify_release_artifacts.mjs --strict",
    "rebuild:native": "node scripts/rebuild_native.mjs",
    "build": "npm run typecheck && npm --workspace @roster/desktop run build",
    "package": "npm --workspace @roster/desktop run package"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.12",
    "archiver": "^7.0.1",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "extract-zip": "^2.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.468.0",
    "octokit": "^4.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@eslint/js": "^9.38.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/archiver": "^6.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.18.10",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^5.4.20",
    "vitest": "^2.1.9"
  }
}
